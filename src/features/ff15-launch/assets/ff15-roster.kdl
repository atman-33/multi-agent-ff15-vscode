layout {
	cwd "__FF15_WORKSPACE_ROOT__"
	pane split_direction="vertical" {
		pane split_direction="horizontal" {
			pane command="__FF15_OPENCODE_COMMAND__" {
				args "--agent" "noctis"
			}
			pane command="__FF15_OPENCODE_COMMAND__" {
				args "--agent" "ignis"
			}
		}
		pane split_direction="horizontal" {
			pane command="__FF15_OPENCODE_COMMAND__" {
				args "--agent" "gladiolus"
			}
			pane command="__FF15_OPENCODE_COMMAND__" {
				args "--agent" "prompto"
			}
		}
	}
}