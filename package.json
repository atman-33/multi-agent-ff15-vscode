{
  "name": "multi-agent-ff15-vscode",
  "displayName": "multi-agent-ff15",
  "description": "FF15-style launch surface for VS Code.",
  "version": "0.4.0",
  "author": "atman-33",
  "publisher": "atman-dev",
  "icon": "icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/atman-33/multi-agent-ff15-vscode"
  },
  "engines": {
    "vscode": "^1.84.0"
  },
  "categories": [],
  "activationEvents": [],
  "main": "dist/extension.js",
  "extensionKind": [
    "workspace",
    "ui"
  ],
  "scripts": {
    "install:all": "npm install && cd webview-ui && npm install",
    "build:ext": "esbuild src/extension.ts --bundle --platform=node --target=node16 --external:vscode --outfile=dist/extension.js",
    "build": "npm run build:ext && npm run build:webview",
    "vscode:prepublish": "npm run build",
    "compile": "npm run build && npm run package",
    "watch": "concurrently \"tsc -w -p ./\" \"npm:watch:webview\"",
    "package": "vsce package",
    "fix": "ultracite fix",
    "check": "ultracite check",
    "test": "vitest run",
    "test:watch": "vitest --watch",
    "test:coverage": "vitest --coverage",
    "prepare": "husky",
    "--- WEBVIEW ---": "--- --- --- --- ---",
    "build:webview": "npm --prefix webview-ui run build",
    "watch:webview": "npm --prefix webview-ui run dev"
  },
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "multi-agent-ff15-vscode",
          "title": "FF15",
          "icon": "./icons/sidebar.svg"
        },
        {
          "id": "multi-agent-ff15-vscode-openCodeSidebar",
          "title": "OpenCode",
          "icon": "./icons/opencode.svg"
        }
      ]
    },
    "views": {
      "multi-agent-ff15-vscode": [
        {
          "id": "multi-agent-ff15-vscode.projectsView",
          "name": "Projects",
          "type": "webview",
          "icon": ""
        },
        {
          "id": "multi-agent-ff15-vscode.missionsView",
          "name": "Missions",
          "type": "webview",
          "icon": ""
        },
        {
          "id": "multi-agent-ff15-vscode.settingsView",
          "name": "Settings",
          "type": "webview",
          "icon": ""
        }
      ],
      "multi-agent-ff15-vscode-openCodeSidebar": [
        {
          "type": "webview",
          "id": "multi-agent-ff15-vscode.openCodeSidebar.chatView",
          "name": "Chat"
        }
      ]
    },
    "commands": [
      {
        "command": "multi-agent-ff15-vscode.initializeWorkspace",
        "title": "Initialize Workspace",
        "category": "FF15"
      },
      {
        "command": "multi-agent-ff15-vscode.openSettings",
        "title": "Open FF15 Settings",
        "category": "FF15"
      },
      {
        "command": "multi-agent-ff15-vscode.openCode.addToChat",
        "title": "OpenCode: Add to Chat",
        "icon": "$(add)"
      },
      {
        "command": "multi-agent-ff15-vscode.openCode.toggleChatView",
        "title": "OpenCode: Toggle Chat View"
      },
      {
        "command": "multi-agent-ff15-vscode.openCode.restart",
        "title": "OpenCode: Restart"
      },
      {
        "command": "multi-agent-ff15-vscode.openCode.addSelectionToChat",
        "title": "OpenCode: Add Selection to Chat",
        "icon": "$(add)"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "command": "multi-agent-ff15-vscode.openCode.addToChat",
          "group": "navigation"
        }
      ],
      "editor/title/context": [
        {
          "command": "multi-agent-ff15-vscode.openCode.addToChat",
          "group": "navigation"
        }
      ],
      "editor/context": [
        {
          "command": "multi-agent-ff15-vscode.openCode.addSelectionToChat",
          "when": "editorHasSelection",
          "group": "navigation"
        }
      ]
    },
    "configuration": {
      "title": "FF15",
      "properties": {
        "multi-agent-ff15-vscode.launchClient": {
          "type": "string",
          "enum": [
            "opencode",
            "github-copilot-cli"
          ],
          "enumDescriptions": [
            "Default. Launch each FF15 roster pane with OpenCode (`opencode --agent <agent>`).",
            "Launch each FF15 roster pane with GitHub Copilot CLI (`copilot`)."
          ],
          "default": "opencode",
          "description": "Select which launch client FF15 uses for its fixed roster panes."
        },
        "multi-agent-ff15-vscode.openCode.port": {
          "type": "number",
          "default": 0,
          "minimum": 0,
          "maximum": 65535,
          "description": "Fixed port for the OpenCode server. Set to 0 (default) to use a random port. Note: changing the port resets preferences stored in the webview since they are tied to the origin."
        },
        "multi-agent-ff15-vscode.openCode.path": {
          "type": "string",
          "default": "",
          "description": "Full path to the OpenCode CLI executable. Leave empty to run opencode from PATH."
        },
        "multi-agent-ff15-vscode.openCode.exposeToNetwork": {
          "type": "boolean",
          "default": false,
          "description": "Expose the OpenCode server to the local network via mDNS. When enabled, you can access the same instance from another device at http://opencode.local:<port>."
        },
        "multi-agent-ff15-vscode.applyModelsBeforeSend": {
          "type": "boolean",
          "default": true,
          "description": "Before sending a prompt, re-apply each agent's party-roster model and variant/effort to every live agent pane so OpenCode matches what the mission screen shows."
        },
        "multi-agent-ff15-vscode.promptInputDelayMs": {
          "type": "number",
          "default": 1000,
          "minimum": 0,
          "description": "Delay (ms) between pane input steps, and the wait after applying models before a prompt is sent. Increase if OpenCode needs more time to process model/variant commands."
        }
      }
    }
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.6",
    "@jest/globals": "^29.7.0",
    "@types/cross-spawn": "^6.0.6",
    "@types/glob": "^8.1.0",
    "@types/node": "^20.x",
    "@types/vscode": "^1.84.0",
    "@vitest/ui": "^3.2.4",
    "concurrently": "^9.2.0",
    "copy-webpack-plugin": "^14.0.0",
    "esbuild": "^0.28.0",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "ts-jest": "^29.4.0",
    "ts-loader": "^9.5.2",
    "typescript": "^5.3.0",
    "ultracite": "^6.3.4",
    "vitest": "^3.2.4",
    "vsce": "^1.97.0"
  },
  "dependencies": {
    "cross-spawn": "^7.0.3",
    "tree-kill": "^1.2.2",
    "yaml": "^2.9.0"
  }
}