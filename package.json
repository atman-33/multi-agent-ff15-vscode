{
  "name": "multi-agent-ff15-vscode",
  "displayName": "multi-agent-ff15-vscode",
  "description": "FF15-style launch surface for VS Code.",
  "version": "0.2.0",
  "author": "atman-33",
  "publisher": "atman-dev",
  "icon": "icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/atman-33/multi-agent-ff15-vscode"
  },
  "engines": {
    "vscode": "^1.84.0"
  },
  "categories": [],
  "activationEvents": [],
  "main": "dist/extension.js",
  "extensionKind": [
    "workspace",
    "ui"
  ],
  "scripts": {
    "install:all": "npm install && cd webview-ui && npm install",
    "build:ext": "esbuild src/extension.ts --bundle --platform=node --target=node16 --external:vscode --outfile=dist/extension.js",
    "build": "npm run build:ext && npm run build:webview",
    "vscode:prepublish": "npm run build",
    "compile": "npm run build && npm run package",
    "watch": "concurrently \"tsc -w -p ./\" \"npm:watch:webview\"",
    "package": "vsce package",
    "lint": "ultracite lint",
    "format": "ultracite format",
    "check": "ultracite check",
    "test": "vitest run",
    "test:watch": "vitest --watch",
    "test:coverage": "vitest --coverage",
    "prepare": "husky",
    "--- WEBVIEW ---": "--- --- --- --- ---",
    "build:webview": "npm --prefix webview-ui run build",
    "watch:webview": "npm --prefix webview-ui run dev"
  },
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "multi-agent-ff15-vscode",
          "title": "FF15",
          "icon": "./icons/sidebar.svg"
        }
      ]
    },
    "views": {
      "multi-agent-ff15-vscode": [
        {
          "id": "multi-agent-ff15-vscode.projectsView",
          "name": "Projects",
          "type": "webview",
          "icon": ""
        },
        {
          "id": "multi-agent-ff15-vscode.missionsView",
          "name": "Missions",
          "type": "webview",
          "icon": ""
        },
        {
          "id": "multi-agent-ff15-vscode.settingsView",
          "name": "Settings",
          "type": "webview",
          "icon": ""
        }
      ]
    },
    "commands": [
      {
        "command": "multi-agent-ff15-vscode.openSettings",
        "title": "Open FF15 Settings",
        "category": "FF15"
      }
    ],
    "configuration": {
      "title": "FF15",
      "properties": {
        "multi-agent-ff15-vscode.launchClient": {
          "type": "string",
          "enum": [
            "opencode",
            "github-copilot-cli"
          ],
          "enumDescriptions": [
            "Default. Launch each FF15 roster pane with OpenCode (`opencode --agent <agent>`).",
            "Launch each FF15 roster pane with GitHub Copilot CLI (`copilot`)."
          ],
          "default": "opencode",
          "description": "Select which launch client FF15 uses for its fixed roster panes."
        }
      }
    }
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.6",
    "@jest/globals": "^29.7.0",
    "@types/glob": "^8.1.0",
    "@types/node": "^20.x",
    "@types/vscode": "^1.84.0",
    "@vitest/ui": "^3.2.4",
    "concurrently": "^9.2.0",
    "copy-webpack-plugin": "^14.0.0",
    "esbuild": "^0.28.0",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "ts-jest": "^29.4.0",
    "ts-loader": "^9.5.2",
    "typescript": "^5.3.0",
    "ultracite": "^6.3.4",
    "vitest": "^3.2.4",
    "vsce": "^1.97.0"
  },
  "dependencies": {
    "yaml": "^2.9.0"
  }
}
